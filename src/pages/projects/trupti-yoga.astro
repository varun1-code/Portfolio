---
import ProjectLayout from '../../layouts/ProjectLayout.astro';

const steps = [
  {
    step: "01",
    title: "User Registration",
    desc: "New users register with their details. Passwords are hashed using SHA-256 before storage. JWT-style session tokens are issued on login for secure, stateless authentication.",
  },
  {
    step: "02",
    title: "Payment Submission",
    desc: "Users submit their UPI transaction ID after completing payment. The system stores the transaction reference and flags the account as pending admin approval.",
  },
  {
    step: "03",
    title: "Admin Approval Workflow",
    desc: "Admins log into a dedicated admin panel to view pending members, verify payment submissions, and approve or reject accounts. Approved members gain full access to sessions.",
  },
  {
    step: "04",
    title: "Real-Time Session Access",
    desc: "The platform detects the current IST time and compares it against the three scheduled daily sessions. Members see a live status indicator showing whether a session is Live, Upcoming, or Ended, auto-refreshing every 30 seconds.",
  },
  {
    step: "05",
    title: "Google Meet Integration",
    desc: "Admins manage Google Meet links through the admin panel, persisted in the database. Active members see the current session link and can join directly from the platform.",
  },
];

const techStack = [
  { name: "React 19", role: "Frontend UI with component-based architecture" },
  { name: "Vite", role: "Fast development build tool" },
  { name: "Tailwind CSS v4", role: "Utility-first styling" },
  { name: "FastAPI", role: "Python backend REST API" },
  { name: "SQLite", role: "Lightweight relational database" },
  { name: "SHA-256", role: "Password hashing for secure storage" },
  { name: "Pytest", role: "30 backend API tests" },
  { name: "Vitest", role: "23 frontend logic tests" },
  { name: "Vercel", role: "Frontend deployment" },
];

const highlights = [
  "Production platform serving a live online yoga business with real paying members",
  "JWT-style authentication with SHA-256 password hashing and session token management",
  "Manual UPI payment verification workflow with admin approve or reject controls",
  "Real-time session status system with IST timezone detection, auto-refreshing every 30 seconds",
  "Role-based admin panel for user and Google Meet link management",
  "53 unit tests covering authentication, payment, session timing, and timezone conversion",
];
---
<ProjectLayout title="Trupti Yoga and Nature Cure">

  <!-- Header -->
  <div data-reveal class="mb-12">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-xs font-mono px-2.5 py-1 rounded border text-green-400 bg-green-400/10 border-green-400/30">Full-Stack</span>
      <span class="text-xs font-mono px-2.5 py-1 rounded border text-slate-400 bg-slate-400/10 border-slate-700">Production App</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-3">Trupti Yoga &amp; Nature Cure</h1>
    <p class="text-slate-400 text-lg leading-relaxed mb-6">
      A production-ready full-stack membership platform for a live online yoga business, handling user registration, UPI payment verification, admin approval, and real-time Google Meet session access.
    </p>
    <div class="flex flex-wrap gap-3">
      <a href="https://trupti-yoga-website.vercel.app/" target="_blank" rel="noopener"
        class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-400 text-slate-900 rounded font-semibold text-sm hover:bg-cyan-300 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
        Live Site
      </a>
      <a href="https://github.com/varun1-code/trupti-yoga-website" target="_blank" rel="noopener"
        class="inline-flex items-center gap-2 px-4 py-2 border border-slate-600 text-slate-300 rounded font-semibold text-sm hover:border-cyan-400 hover:text-cyan-400 transition-all">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>

  <!-- Overview -->
  <section data-reveal class="mb-12">
    <h2 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
      <span class="text-cyan-400 font-mono text-sm">01.</span> Overview
    </h2>
    <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 text-slate-400 leading-relaxed space-y-4">
      <p>
        Trupti Yoga and Nature Cure is a real business offering online yoga sessions. The owner needed a platform where members could register, pay via UPI, and access live Google Meet sessions. This project was built and deployed for actual use by real members.
      </p>
      <p>
        The platform solves a practical problem: how to verify informal UPI payments and control access to live sessions. Rather than relying on automated payment gateways, it implements a manual verification workflow where users submit their UPI transaction ID and an admin approves their membership after confirming the payment.
      </p>
    </div>
  </section>

  <!-- How it works -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-white mb-6 flex items-center gap-2">
      <span class="text-cyan-400 font-mono text-sm">02.</span> How It Works
    </h2>
    <div class="space-y-4">
      {steps.map(s => (
        <div class="flex gap-5 bg-slate-900 border border-slate-800 rounded-xl p-5 hover:border-cyan-400/30 transition-colors">
          <span class="font-mono text-cyan-400 text-xl font-bold shrink-0">{s.step}</span>
          <div>
            <h3 class="text-white font-semibold mb-1">{s.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-white mb-6 flex items-center gap-2">
      <span class="text-cyan-400 font-mono text-sm">03.</span> Tech Stack
    </h2>
    <div class="grid sm:grid-cols-2 gap-3">
      {techStack.map(t => (
        <div class="flex items-start gap-3 bg-slate-900 border border-slate-800 rounded-lg p-4 hover:border-cyan-400/30 transition-colors">
          <span class="text-cyan-400 mt-0.5 shrink-0">▸</span>
          <div>
            <p class="text-white text-sm font-semibold">{t.name}</p>
            <p class="text-slate-500 text-xs">{t.role}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Key Highlights -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-white mb-6 flex items-center gap-2">
      <span class="text-cyan-400 font-mono text-sm">04.</span> Key Highlights
    </h2>
    <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
      <ul class="space-y-3">
        {highlights.map(h => (
          <li class="flex items-start gap-3 text-slate-400 text-sm leading-relaxed">
            <span class="text-cyan-400 mt-0.5 shrink-0">✓</span>
            {h}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Testing -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-white mb-6 flex items-center gap-2">
      <span class="text-cyan-400 font-mono text-sm">05.</span> Testing
    </h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 text-center">
        <p class="text-4xl font-bold text-cyan-400 mb-1">30</p>
        <p class="text-white font-medium text-sm mb-1">Backend Tests</p>
        <p class="text-slate-500 text-xs">Pytest covering API endpoints, auth flows, and payment logic</p>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 text-center">
        <p class="text-4xl font-bold text-cyan-400 mb-1">23</p>
        <p class="text-white font-medium text-sm mb-1">Frontend Tests</p>
        <p class="text-slate-500 text-xs">Vitest covering session timing, timezone conversion, and UI logic</p>
      </div>
    </div>
  </section>

</ProjectLayout>
