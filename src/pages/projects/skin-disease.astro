---
import ProjectLayout from '../../layouts/ProjectLayout.astro';

const steps = [
  { step: "01", title: "Dataset Preparation", desc: "The HAM10000 dataset with 10,000 labeled skin lesion images across 7 disease classes is loaded and split into training, validation, and test sets. Class imbalance is handled using weighted sampling to prevent the model from favouring majority classes." },
  { step: "02", title: "Preprocessing and Augmentation", desc: "Images are normalized using ImageNet mean and standard deviation. Augmentation techniques including random flips, colour jitter, and rotation are applied during training to improve model generalization." },
  { step: "03", title: "Multi-Model Training", desc: "Three base models are trained independently: EfficientNet-B0, EfficientNet-B3, and ResNet50. Each uses transfer learning from ImageNet weights with fine-tuning on the skin lesion dataset. Models are exported using TorchScript for deployment." },
  { step: "04", title: "Ensemble with Meta-Learner", desc: "Predictions from all three base models are combined using a stacking ensemble approach. A meta-learner trained on base model outputs produces a final prediction, achieving 87.3% accuracy on the test set of 1,503 images." },
  { step: "05", title: "Real-Time Inference", desc: "The trained ensemble is served via a FastAPI backend. A Streamlit frontend allows users to upload a skin lesion image and receive an instant classification result with the predicted disease class and confidence score." },
];

const techStack = [
  { name: "PyTorch", role: "Deep learning framework for model training and inference" },
  { name: "EfficientNet-B0 and B3", role: "Base models using transfer learning from ImageNet" },
  { name: "ResNet50", role: "Third base model in the ensemble stack" },
  { name: "TorchScript", role: "Model export format for production deployment" },
  { name: "FastAPI", role: "Backend API for serving predictions" },
  { name: "Streamlit", role: "Interactive web interface for image upload and results" },
  { name: "HAM10000 Dataset", role: "10,000 labeled dermatology images across 7 disease classes" },
];

const diseases = ["Melanocytic Nevi", "Melanoma", "Benign Keratosis", "Basal Cell Carcinoma", "Actinic Keratosis", "Vascular Lesions", "Dermatofibroma"];

const highlights = [
  "Ensemble of three deep learning models achieving 87.3% accuracy on a 1,503 image test set",
  "Transfer learning from ImageNet weights with fine-tuning on dermatology data",
  "Weighted sampling to handle significant class imbalance across 7 disease categories",
  "Stacking meta-learner combines base model predictions for improved robustness",
  "TorchScript export enables efficient production deployment",
  "End-to-end pipeline from raw dataset to real-time inference via FastAPI and Streamlit",
];
---
<ProjectLayout title="Skin Disease Detection">

  <div data-reveal class="mb-12">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-xs font-mono px-2.5 py-1 rounded border text-blue-400 bg-blue-400/10 border-blue-400/30">AI / ML</span>
      <span class="text-xs font-mono px-2.5 py-1 rounded border text-slate-400 bg-slate-400/10 border-slate-700">Academic Project</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-3">Skin Disease Detection</h1>
    <p class="text-slate-400 text-lg leading-relaxed mb-6">
      A deep learning system for multi-class skin disease classification using an ensemble of CNN models, achieving 87.3% accuracy on the HAM10000 dataset across 7 disease categories.
    </p>
    <a href="https://github.com/varun1-code/Skin-deases-detection-" target="_blank" rel="noopener"
      class="inline-flex items-center gap-2 px-4 py-2 border border-slate-600 text-slate-300 rounded font-semibold text-sm hover:border-cyan-400 hover:text-cyan-400 transition-all">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
      </svg>
      GitHub
    </a>
  </div>

  <section data-reveal class="mb-12">
    <h2 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
      <span class="text-cyan-400 font-mono text-sm">01.</span> Overview
    </h2>
    <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 text-slate-400 leading-relaxed space-y-4">
      <p>Skin cancer is one of the most common cancers worldwide, and early detection significantly improves treatment outcomes. This project explores how deep learning can assist in classifying skin lesions from dermoscopy images into seven distinct categories, supporting early diagnosis.</p>
      <p>Rather than relying on a single model, the project implements a stacking ensemble where three independently trained CNN models contribute to a final prediction via a meta-learner, improving robustness and accuracy compared to any single model alone.</p>
    </div>
  </section>

  <section data-reveal class="mb-12">
    <h2 class="text-xl font-semibold text-white mb-6 flex items-center gap-2">
      <span class="text-cyan-400 font-mono text-sm">02.</span> Disease Classes
    </h2>
    <div data-reveal-group class="grid sm:grid-cols-2 gap-2">
      {diseases.map((d, i) => (
        <div class="flex items-center gap-3 bg-slate-900 border border-slate-800 rounded-lg px-4 py-3 font-mono text-sm text-cyan-400/80 hover:border-cyan-400/30 transition-colors">
          <span class="text-slate-600 text-xs">{String(i + 1).padStart(2, '0')}</span>{d}
        </div>
      ))}
    </div>
  </section>

  <section data-reveal class="mb-12">
    <h2 class="text-xl font-semibold text-white mb-6 flex items-center gap-2">
      <span class="text-cyan-400 font-mono text-sm">03.</span> How It Works
    </h2>
    <div data-reveal-group class="space-y-4">
      {steps.map(s => (
        <div class="flex gap-5 bg-slate-900 border border-slate-800 rounded-xl p-5 hover:border-cyan-400/30 transition-colors">
          <span class="font-mono text-cyan-400 text-xl font-bold shrink-0">{s.step}</span>
          <div>
            <h3 class="text-white font-semibold mb-1">{s.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section data-reveal class="mb-12">
    <h2 class="text-xl font-semibold text-white mb-6 flex items-center gap-2">
      <span class="text-cyan-400 font-mono text-sm">04.</span> Tech Stack
    </h2>
    <div data-reveal-group class="grid sm:grid-cols-2 gap-3">
      {techStack.map(t => (
        <div class="flex items-start gap-3 bg-slate-900 border border-slate-800 rounded-lg p-4 hover:border-cyan-400/30 transition-colors">
          <span class="text-cyan-400 mt-0.5 shrink-0">▸</span>
          <div>
            <p class="text-white text-sm font-semibold">{t.name}</p>
            <p class="text-slate-500 text-xs">{t.role}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section data-reveal class="mb-12">
    <h2 class="text-xl font-semibold text-white mb-6 flex items-center gap-2">
      <span class="text-cyan-400 font-mono text-sm">05.</span> Results
    </h2>
    <div data-reveal-group class="grid sm:grid-cols-3 gap-4 mb-6">
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 text-center hover:border-cyan-400/30 transition-colors">
        <p class="text-4xl font-bold text-cyan-400 mb-1">87.3%</p>
        <p class="text-white font-medium text-sm">Ensemble Accuracy</p>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 text-center hover:border-cyan-400/30 transition-colors">
        <p class="text-4xl font-bold text-cyan-400 mb-1">10K+</p>
        <p class="text-white font-medium text-sm">Training Images</p>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 text-center hover:border-cyan-400/30 transition-colors">
        <p class="text-4xl font-bold text-cyan-400 mb-1">7</p>
        <p class="text-white font-medium text-sm">Disease Classes</p>
      </div>
    </div>
    <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
      <ul class="space-y-3">
        {highlights.map(h => (
          <li class="flex items-start gap-3 text-slate-400 text-sm leading-relaxed">
            <span class="text-cyan-400 mt-0.5 shrink-0">✓</span>{h}
          </li>
        ))}
      </ul>
    </div>
  </section>

</ProjectLayout>
