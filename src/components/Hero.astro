---
---
<section id="hero" class="min-h-screen flex items-center justify-center relative overflow-hidden">
  <!-- Background grid -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(34,211,238,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(34,211,238,0.03)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
  <!-- Floating glow blobs -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[700px] h-[700px] bg-cyan-500/5 rounded-full blur-3xl pointer-events-none float-slow"></div>
  <div class="absolute top-1/2 left-1/4 w-72 h-72 bg-blue-500/5 rounded-full blur-2xl pointer-events-none float"></div>
  <div class="absolute bottom-1/4 right-1/4 w-56 h-56 bg-purple-500/5 rounded-full blur-2xl pointer-events-none float-slow" style="animation-delay: 3s;"></div>

  <div class="relative max-w-6xl mx-auto px-6 py-32 text-center">
    <p class="font-mono text-cyan-400 text-sm tracking-widest mb-6 opacity-0 animate-[fadeInUp_0.6s_ease_0.1s_forwards]">
      Hi, I'm
    </p>
    <h1 class="text-5xl md:text-7xl font-bold text-white mb-4 opacity-0 animate-[fadeInUp_0.6s_ease_0.3s_forwards]">
      Varun <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">K.V</span>
    </h1>
    <h2 class="text-xl md:text-2xl text-slate-400 font-medium mb-4 opacity-0 animate-[fadeInUp_0.6s_ease_0.5s_forwards]">
      AI/ML Engineer &amp; Backend Developer
    </h2>
    <p class="font-medium text-cyan-400/80 text-base mb-6 opacity-0 animate-[fadeInUp_0.6s_ease_0.6s_forwards]">
      Building AI-powered applications and scalable backend systems.
    </p>
    <p class="max-w-2xl mx-auto text-slate-500 text-base md:text-lg leading-relaxed mb-10 opacity-0 animate-[fadeInUp_0.6s_ease_0.7s_forwards]">
      Passionate about Artificial Intelligence, Machine Learning, and Backend Development. I build intelligent applications using Python, FastAPI, TensorFlow, and modern AI technologies, focusing on scalable solutions, automation, and real-world impact.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-4 opacity-0 animate-[fadeInUp_0.6s_ease_0.9s_forwards]">
      <a href="#projects" class="px-6 py-3 bg-cyan-400 text-slate-900 rounded font-semibold hover:bg-cyan-300 transition-colors duration-200">
        View Projects
      </a>
      <a href="#contact" class="px-6 py-3 border border-slate-600 text-slate-300 rounded font-semibold hover:border-cyan-400 hover:text-cyan-400 transition-all duration-200">
        Get in Touch
      </a>
    </div>
    <div class="flex items-center justify-center gap-6 mt-10 opacity-0 animate-[fadeInUp_0.6s_ease_1.1s_forwards]">
      <a href="https://github.com/varun1-code" target="_blank" rel="noopener" class="text-slate-500 hover:text-cyan-400 transition-colors" aria-label="GitHub">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
        </svg>
      </a>
      <a href="https://linkedin.com/in/varun-kv-bunny" target="_blank" rel="noopener" class="text-slate-500 hover:text-cyan-400 transition-colors" aria-label="LinkedIn">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="mailto:varunkvvarunkv1@gmail.com" class="text-slate-500 hover:text-cyan-400 transition-colors" aria-label="Email">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-[fadeInUp_0.6s_ease_1.3s_forwards]">
      <div class="w-6 h-10 border-2 border-slate-600 rounded-full flex justify-center pt-2">
        <div class="w-1 h-2 bg-cyan-400 rounded-full animate-bounce"></div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
