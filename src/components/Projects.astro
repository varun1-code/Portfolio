---
const projects = [
  {
    title: "Earnings Call Research Tool",
    description: "LLM-powered research tool that analyses earnings call transcripts and produces analyst-ready outputs. Every extracted point is grounded in a direct quote from the transcript; missing sections return null instead of hallucinating.",
    tags: ["Python", "LLM API", "Prompt Engineering", "Streamlit", "Docker", "OCR", "PyMuPDF"],
    highlights: ["Strict hallucination control via quote-grounding", "Multi-format ingestion (PDF, DOCX, TXT + OCR fallback)", "Containerised with Docker, exported to JSON and PDF"],
    github: null,
    live: "https://earnings-call-research-tool-1.onrender.com/",
    detail: "/projects/earnings-call",
    type: "AI / LLM",
  },
  {
    title: "Trupti Yoga & Nature Cure",
    description: "Production-ready membership platform for a live online yoga business. Handles user registration, UPI payment verification, admin approval workflow, and real-time Google Meet session access with IST timezone detection.",
    tags: ["React 19", "Vite", "Tailwind CSS", "FastAPI", "SQLite", "REST API"],
    highlights: ["JWT-style auth with SHA-256 password hashing", "Real-time session status auto-refreshing every 30 seconds", "53 unit tests covering auth, payment, and session timing"],
    github: "https://github.com/varun1-code/trupti-yoga-website",
    live: "https://trupti-yoga-website.vercel.app",
    detail: "/projects/trupti-yoga",
    type: "Full-Stack",
  },
  {
    title: "Skin Disease Detection",
    description: "Deep learning system for multi-class skin disease classification using an ensemble of CNN models achieving 87.3% accuracy on the HAM10000 dataset across 7 disease classes.",
    tags: ["PyTorch", "CNN", "Transfer Learning", "EfficientNet", "FastAPI", "Streamlit"],
    highlights: ["Ensemble of EfficientNet-B0, EfficientNet-B3, and ResNet50", "87.3% accuracy on 1,503 image test set", "Stacking meta-learner with weighted sampling for class imbalance"],
    github: "https://github.com/varun1-code/Skin-deases-detection-",
    live: null,
    detail: "/projects/skin-disease",
    type: "AI / ML",
  },
  {
    title: "Cricket Analytics Dashboard",
    description: "End-to-end analytics pipeline ingesting raw cricket match data, cleaning and transforming with SQL, then visualised in an interactive Power BI dashboard with dynamic filters for team, player, and format.",
    tags: ["SQL", "Power BI", "Data Analysis", "KPIs"],
    highlights: ["KPIs: batting average, strike rate, economy rate, win probability", "Interactive drill-down filters for non-technical stakeholders", "Full ETL pipeline from raw data to dashboard"],
    github: null,
    live: null,
    detail: "/projects/cricket-analytics",
    type: "Data Analytics",
  },
];

const typeColors: Record<string, string> = {
  "AI / LLM": "text-purple-400 bg-purple-400/10 border-purple-400/30",
  "Full-Stack": "text-green-400 bg-green-400/10 border-green-400/30",
  "AI / ML": "text-blue-400 bg-blue-400/10 border-blue-400/30",
  "Data Analytics": "text-orange-400 bg-orange-400/10 border-orange-400/30",
};
---
<section id="projects" class="py-24 bg-slate-900/50">
  <div class="max-w-6xl mx-auto px-6">
    <div data-reveal class="flex items-center gap-4 mb-16">
      <span class="font-mono text-cyan-400 text-sm glow">03.</span>
      <h2 class="text-2xl md:text-3xl font-bold text-white">Projects</h2>
      <div class="flex-1 h-px bg-slate-800"></div>
    </div>

    <div data-reveal-group class="grid md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 flex flex-col hover:border-cyan-400/40 hover:-translate-y-1 transition-all duration-300">
          <div class="flex items-start justify-between mb-3">
            <span class={`text-xs font-mono px-2.5 py-1 rounded border ${typeColors[project.type]}`}>
              {project.type}
            </span>
            <div class="flex gap-3">
              {project.live && (
                <a href={project.live} target="_blank" rel="noopener" class="text-slate-500 hover:text-cyan-400 transition-colors" aria-label="Live demo">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </a>
              )}
              {project.github && (
                <a href={project.github} target="_blank" rel="noopener" class="text-slate-500 hover:text-cyan-400 transition-colors" aria-label="GitHub">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
                  </svg>
                </a>
              )}
            </div>
          </div>

          <h3 class="text-white font-semibold text-lg mb-2">{project.title}</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-4 flex-1">{project.description}</p>

          <ul class="space-y-1 mb-5">
            {project.highlights.map(h => (
              <li class="flex items-start gap-2 text-xs text-slate-500">
                <span class="text-cyan-400 mt-0.5">▸</span>
                {h}
              </li>
            ))}
          </ul>

          <div class="flex flex-wrap gap-2 pb-4 border-b border-slate-800 mb-4">
            {project.tags.map(tag => (
              <span class="font-mono text-xs text-cyan-400/70 bg-cyan-400/5 px-2 py-0.5 rounded">
                {tag}
              </span>
            ))}
          </div>

          <a href={project.detail} class="inline-flex items-center gap-2 text-sm font-medium text-cyan-400 hover:text-cyan-300 transition-colors group">
            View Project Details
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
