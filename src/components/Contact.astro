<section id="contact" class="py-24 bg-slate-900/50">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <div data-reveal class="flex items-center gap-4 mb-16">
      <div class="flex-1 h-px bg-slate-800"></div>
      <span class="font-mono text-cyan-400 text-sm glow">07.</span>
      <h2 class="text-2xl md:text-3xl font-bold text-white">Get In Touch</h2>
      <div class="flex-1 h-px bg-slate-800"></div>
    </div>

    <div data-reveal class="bg-slate-900 border border-slate-800 rounded-2xl p-8 md:p-12">
      <p class="text-slate-400 text-lg leading-relaxed mb-8 max-w-xl mx-auto">
        I'm actively seeking opportunities in <span class="text-cyan-400 font-medium">AI/ML Engineering</span> and <span class="text-cyan-400 font-medium">Python Backend Development</span>. If you have a role, an interesting project, or would simply like to connect, I'd be happy to hear from you.
      </p>

      <a
        href="mailto:varunkvvarunkv1@gmail.com"
        class="inline-flex items-center gap-3 px-8 py-4 bg-cyan-400 text-slate-900 rounded-lg font-semibold text-lg hover:bg-cyan-300 transition-colors duration-200 mb-10"
