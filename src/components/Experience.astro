---
const experience = [
  {
    role: "Backend Developer Intern",
    company: "Learnyst",
    type: "EdTech Platform",
    period: "Feb 2026 – May 2026",
    location: "Bangalore, Karnataka",
    stack: ["Ruby on Rails", "Sidekiq", "Redis", "GraphQL", "Webhooks"],
    bullets: [
      "Shipped production backend features — email validation system with foreground (real-time) and background (bulk) processing flows",
      "Designed a vendor adapter using the Strategy design pattern, enabling third-party providers to be swapped without touching business logic",
      "Handled vendor webhooks for async validation callbacks with status reconciliation and retry handling",
      "Built a Sidekiq-driven reporting pipeline generating deliverability reports emailed to admins",
      "Exposed validation data through GraphQL APIs, reducing over-fetching in the admin dashboard",
    ],
  },
];

const education = [
  {
    degree: "B.E. in Computer Science",
    institution: "Maharaja Institute of Technology, Mysore",
    period: "Completed June 2026",
    score: "SGPA: 8.56",
  },
  {
    degree: "Pre-University (PUC)",
    institution: "BGS PU College",
    period: "Completed July 2021",
    score: "94.36%",
  },
  {
    degree: "Secondary School (SSLC)",
    institution: "CKS English School, Hassan",
    period: "Completed April 2019",
    score: "91%",
  },
];

const certifications = [
  { name: "Artificial Intelligence Fundamentals", issuer: "IBM SkillsBuild", year: "2025", file: "/certificates/ibm.pdf" },
  { name: "AI & Data Science Applications", issuer: "TejasPro Trainings", year: "2025", file: "/certificates/tejaspro.jpg" },
  { name: "Python Full Stack Course", issuer: "Pentagon Space", year: "2026", file: "/certificates/pentagon.jpeg" },
  { name: "Backend Developer Intern", issuer: "Learnyst", year: "2026", file: "/certificates/learnyst.pdf" },
];
---
<section id="experience" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div data-reveal class="flex items-center gap-4 mb-16">
      <span class="font-mono text-cyan-400 text-sm glow">04.</span>
      <h2 class="text-2xl md:text-3xl font-bold text-white">Experience</h2>
      <div class="flex-1 h-px bg-slate-800"></div>
    </div>

    <!-- Work Experience -->
    <div data-reveal class="mb-16">
      {experience.map(exp => (
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 md:p-8 hover:border-cyan-400/40 transition-all duration-300">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-5">
            <div>
              <h3 class="text-white text-xl font-semibold">{exp.role}</h3>
              <p class="text-cyan-400 font-medium">{exp.company} <span class="text-slate-500 font-normal">— {exp.type}</span></p>
            </div>
            <div class="text-right">
              <p class="font-mono text-sm text-slate-400">{exp.period}</p>
              <p class="text-slate-500 text-sm">{exp.location}</p>
            </div>
          </div>
          <ul class="space-y-2 mb-5">
            {exp.bullets.map(b => (
              <li class="flex items-start gap-3 text-slate-400 text-sm leading-relaxed">
                <span class="text-cyan-400 mt-1 shrink-0">▸</span>
                {b}
              </li>
            ))}
          </ul>
          <div class="flex flex-wrap gap-2 pt-4 border-t border-slate-800">
            {exp.stack.map(s => (
              <span class="font-mono text-xs text-cyan-400/70 bg-cyan-400/5 px-2 py-0.5 rounded">{s}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Education & Certifications -->
    <div data-reveal class="grid md:grid-cols-2 gap-8">
      <div>
        <h3 class="text-white font-semibold text-lg mb-5 flex items-center gap-2">
          <span class="text-cyan-400">📚</span> Education
        </h3>
        <div class="space-y-4">
          {education.map(edu => (
            <div class="border-l-2 border-slate-700 pl-4 hover:border-cyan-400 transition-colors">
              <p class="text-white font-medium text-sm">{edu.degree}</p>
              <p class="text-slate-400 text-sm">{edu.institution}</p>
              <div class="flex gap-4 mt-1">
                <span class="font-mono text-xs text-slate-500">{edu.period}</span>
                <span class="font-mono text-xs text-cyan-400">{edu.score}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-white font-semibold text-lg mb-5 flex items-center gap-2">
          <span class="text-cyan-400">🏆</span> Certifications
        </h3>
        <div class="space-y-3">
          {certifications.map(cert => (
            <a href={cert.file} target="_blank" rel="noopener" class="flex items-start gap-3 bg-slate-900 border border-slate-800 rounded-lg p-3 hover:border-cyan-400/40 hover:bg-slate-800/60 transition-all duration-200 group">
              <span class="text-cyan-400 mt-0.5 shrink-0">✓</span>
              <div class="flex-1">
                <p class="text-slate-200 text-sm font-medium group-hover:text-cyan-400 transition-colors">{cert.name}</p>
                <p class="text-slate-500 text-xs">{cert.issuer} · {cert.year}</p>
              </div>
              <svg class="w-3.5 h-3.5 text-slate-600 group-hover:text-cyan-400 transition-colors mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
