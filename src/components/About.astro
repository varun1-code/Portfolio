---
---
<section id="about" class="py-24 bg-slate-900/50">
  <div class="max-w-6xl mx-auto px-6">
    <div data-reveal class="flex items-center gap-4 mb-16">
      <span class="font-mono text-cyan-400 text-sm glow">01.</span>
      <h2 class="text-2xl md:text-3xl font-bold text-white">About Me</h2>
      <div class="flex-1 h-px bg-slate-800"></div>
    </div>

    <div class="grid md:grid-cols-[220px_1fr] gap-12 items-start">

      <!-- Left: profile picture + socials -->
      <div data-reveal class="flex flex-col items-center gap-6">
        <div class="relative w-fit">
          <div class="w-44 h-44 rounded-2xl overflow-hidden border-2 border-cyan-400/30 shadow-lg shadow-cyan-400/10 hover:scale-105 transition-transform duration-300">
            <img src="/profile.jpg" alt="Varun K.V" class="w-full h-full object-cover object-top" />
          </div>
          <div class="absolute -bottom-2 -right-2 w-44 h-44 rounded-2xl border border-cyan-400/20 -z-10"></div>
          <div class="absolute -top-2 -right-2 w-4 h-4 bg-cyan-400 rounded-full shadow-lg shadow-cyan-400/50 float"></div>
        </div>

        <!-- Status badge -->
        <div class="flex items-center gap-2 px-3 py-1.5 bg-green-400/10 border border-green-400/30 rounded-full">
          <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
          <span class="text-green-400 text-xs font-medium">Open to opportunities</span>
        </div>

        <!-- Social links -->
        <div class="flex flex-col gap-2 w-full">
          <a href="https://github.com/varun1-code" target="_blank" rel="noopener"
            class="flex items-center gap-3 px-3 py-2 bg-slate-800/60 border border-slate-700/50 rounded-lg hover:border-cyan-400/40 hover:bg-slate-800 transition-all text-sm text-slate-400 hover:text-cyan-400 group">
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
            <span class="text-xs">varun1-code</span>
          </a>
          <a href="https://linkedin.com/in/varun-kv-bunny" target="_blank" rel="noopener"
            class="flex items-center gap-3 px-3 py-2 bg-slate-800/60 border border-slate-700/50 rounded-lg hover:border-cyan-400/40 hover:bg-slate-800 transition-all text-sm text-slate-400 hover:text-cyan-400">
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span class="text-xs">varun-kv-bunny</span>
          </a>
          <a href="mailto:varunkvvarunkv1@gmail.com"
            class="flex items-center gap-3 px-3 py-2 bg-slate-800/60 border border-slate-700/50 rounded-lg hover:border-cyan-400/40 hover:bg-slate-800 transition-all text-sm text-slate-400 hover:text-cyan-400">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <span class="text-xs truncate">varunkvvarunkv1@gmail.com</span>
          </a>
          <a href="tel:+919663089804"
            class="flex items-center gap-3 px-3 py-2 bg-slate-800/60 border border-slate-700/50 rounded-lg hover:border-cyan-400/40 hover:bg-slate-800 transition-all text-sm text-slate-400 hover:text-cyan-400">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <span class="text-xs">+91 9663089804</span>
          </a>
        </div>
      </div>

      <!-- Right: bio + stat cards -->
      <div data-reveal class="flex flex-col gap-8">

        <div class="space-y-4 text-slate-400 leading-relaxed">
          <div>
            <h3 class="text-white text-xl font-semibold">Hi, I'm Varun K.V</h3>
            <p class="text-slate-300 font-medium mt-1">AI/ML Engineer &amp; Python Backend Developer</p>
          </div>
          <p>
            I'm a <span class="text-slate-200 font-medium">Computer Science graduate</span> from Maharaja Institute of Technology Mysore, passionate about building intelligent systems that solve real-world problems.
          </p>
          <p>
            My work combines <span class="text-cyan-400 font-medium">AI/ML engineering</span> including LLMs, prompt engineering, and computer vision, with <span class="text-cyan-400 font-medium">Python backend development</span> using FastAPI, Flask, and REST APIs. I enjoy taking ideas from concept to deployment and building applications that deliver real value to users.
          </p>
          <p>
            During my internship at <span class="text-slate-200 font-medium">Learnyst</span>, I contributed to production backend systems by integrating third-party APIs, developing asynchronous job pipelines with Sidekiq and Redis, and exposing data through GraphQL services.
          </p>
          <p>
            Beyond software development, I enjoy exploring financial markets and cricket, which inspire several of my data-driven projects at the intersection of technology and domain expertise.
          </p>
        </div>

        <!-- Stat cards -->
        <div data-reveal-group class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {[
            { label: "Languages", value: "Python, JS, SQL, C", icon: "💻" },
            { label: "AI / ML", value: "PyTorch, TensorFlow, LLMs", icon: "🤖" },
            { label: "Backend", value: "FastAPI, Flask, Django", icon: "⚙️" },
            { label: "Frontend", value: "React, Tailwind, Vite", icon: "🎨" },
            { label: "DevOps", value: "Docker, Git, Linux", icon: "🛠️" },
            { label: "Location", value: "Bangalore, KA", icon: "📍" },
          ].map(item => (
            <div class="bg-slate-800/60 border border-slate-700/50 rounded-lg p-3 hover:border-cyan-400/50 hover:bg-slate-800 hover:scale-105 transition-all duration-200 cursor-default">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-base">{item.icon}</span>
                <p class="font-mono text-cyan-400 text-xs">{item.label}</p>
              </div>
              <p class="text-slate-300 text-xs font-medium">{item.value}</p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </div>
</section>
